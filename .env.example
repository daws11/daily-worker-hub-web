# ============================================================
# Daily Worker Hub - Environment Variables Reference
# ============================================================
# Copy this file to .env.local for local development
# Configure these in Vercel Dashboard > Project > Environment Variables
# for Production and Preview environments
#
# IMPORTANT: Never commit actual secrets to version control.
# Use .env.local for local secrets (already gitignored).
# ============================================================

# ──────────────────────────────────────────────────────────────
# SUPABASE (Required)
# ──────────────────────────────────────────────────────────────

# Supabase Project URL (public - used client-side)
# Local: http://127.0.0.1:54321
# Production: https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous Key (public - used client-side)
# Safe to expose to browser via NEXT_PUBLIC_ prefix
# Get from: Supabase Dashboard > Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (SERVER-SIDE ONLY - never expose client-side)
# Used for server-side admin operations (bypasses RLS)
# ⚠️  CRITICAL: Do NOT prefix with NEXT_PUBLIC_
# Get from: Supabase Dashboard > Settings > API > Project API keys > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ──────────────────────────────────────────────────────────────
# APPLICATION URLS (Required)
# ──────────────────────────────────────────────────────────────

# Application base URL (public - used client-side for redirects, OG tags, etc.)
# Production: https://your-domain.com
# Preview: Automatically set by Vercel ($NEXT_PUBLIC_VERCEL_URL)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ──────────────────────────────────────────────────────────────
# SENTRY ERROR TRACKING (Required)
# ──────────────────────────────────────────────────────────────

# Sentry Data Source Name (public - used client-side for browser errors)
# Safe to expose via NEXT_PUBLIC_ prefix (public DSN, not a secret)
# Get from: Sentry Dashboard > Project > Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# Sentry Auth Token (SERVER-SIDE ONLY - CI/CD only)
# Used for uploading source maps during deployment
# ⚠️  CRITICAL: Do NOT prefix with NEXT_PUBLIC_
# Get from: Sentry > Settings > Account > Auth Tokens
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# Sentry Organization Slug
SENTRY_ORG=your-org-slug

# Sentry Project Slug
SENTRY_PROJECT=daily-worker-hub

# ──────────────────────────────────────────────────────────────
# PAYMENT GATEWAY - XENDIT (Required if payment features enabled)
# ──────────────────────────────────────────────────────────────

# Xendit Secret Key (SERVER-SIDE ONLY)
# ⚠️  CRITICAL: Do NOT prefix with NEXT_PUBLIC_
# Get from: Xendit Dashboard > Settings > API Keys > secret key
XENDIT_SECRET_KEY=xnd_live_your-secret-key-here

# Xendit Webhook Verification Token (SERVER-SIDE ONLY)
# ⚠️  CRITICAL: Do NOT prefix with NEXT_PUBLIC_
# Get from: Xendit Dashboard > Developers > Webhooks > Verification Token
XENDIT_WEBHOOK_TOKEN=your-webhook-verification-token-here

# Xendit Public Key (public - used client-side)
NEXT_PUBLIC_XENDIT_PUBLIC_KEY=xnd_public_live_your-public-key-here

# ──────────────────────────────────────────────────────────────
# EMAIL SERVICE - RESEND (Required if email features enabled)
# ──────────────────────────────────────────────────────────────

# Resend API Key (SERVER-SIDE ONLY)
# ⚠️  CRITICAL: Do NOT prefix with NEXT_PUBLIC_
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here

# ──────────────────────────────────────────────────────────────
# FIREBASE / PUSH NOTIFICATIONS (Optional)
# ──────────────────────────────────────────────────────────────

# Firebase Configuration (public - used client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# Firebase Admin SDK (SERVER-SIDE ONLY)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# ──────────────────────────────────────────────────────────────
# SOCIAL MEDIA INTEGRATION (Optional)
# ──────────────────────────────────────────────────────────────

# Instagram Basic Display API
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=https://your-domain.com/auth/instagram/callback

# Facebook Graph API
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_PAGE_ID=your-facebook-page-id

# ──────────────────────────────────────────────────────────────
# WEB PUSH NOTIFICATIONS (Optional)
# ──────────────────────────────────────────────────────────────

# VAPID Public Key (public - used client-side)
NEXT_PUBLIC_VAPID_KEY=your-vapid-public-key-here

# VAPID Keys (SERVER-SIDE ONLY - generate using: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CONTACT_EMAIL=mailto:your-email@example.com

# ──────────────────────────────────────────────────────────────
# UPSTASH REDIS (Optional - for caching/rate limiting)
# ──────────────────────────────────────────────────────────────

# Upstash Redis REST API URL (SERVER-SIDE ONLY)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io

# Upstash Redis REST API Token (SERVER-SIDE ONLY)
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# ──────────────────────────────────────────────────────────────
# ADMIN / SECURITY (Optional)
# ──────────────────────────────────────────────────────────────

# Admin API Secret (SERVER-SIDE ONLY)
ADMIN_API_SECRET=your-admin-secret-here

# Cron Job Security Secret (SERVER-SIDE ONLY)
CRON_SECRET=your-cron-secret-here

# ──────────────────────────────────────────────────────────────
# MIDTRANS (Alternative Payment Gateway - Optional)
# ──────────────────────────────────────────────────────────────

# Midtrans Server Key (SERVER-SIDE ONLY)
MIDTRANS_SERVER_KEY=your-midtrans-server-key

# Midtrans Client Key (public - used client-side)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key

# Midtrans Environment
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_API_URL=https://api.sandbox.midtrans.com
MIDTRANS_SNAP_API_URL=https://app.sandbox.midtrans.com/snap/v1
