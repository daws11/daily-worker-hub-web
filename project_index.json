{
  "project_type": "single",
  "services": {
    "frontend": {
      "path": ".",
      "tech_stack": ["next.js", "typescript", "tailwindcss", "react"],
      "port": 3000,
      "dev_command": "npm run dev",
      "test_command": "npm test",
      "build_command": "npm run build"
    }
  },
  "infrastructure": {
    "docker": false,
    "database": "supabase-postgresql",
    "auth": "supabase-auth"
  },
  "conventions": {
    "linter": "eslint",
    "formatter": "prettier",
    "testing": "vitest"
  },
  "package_manager": "npm"
}
