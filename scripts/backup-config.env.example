# Daily Worker Hub - Supabase Backup Configuration
# Copy this file to backup-config.env and fill in your values
# NEVER commit backup-config.env to version control!

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# Your Supabase project reference (found in project settings)
# Example: abcdefghijklmnop
SUPABASE_PROJECT_REF=your-project-ref-here

# Database connection URL for pg_dump
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# Get this from: Supabase Dashboard > Settings > Database > Connection string
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ============================================================================
# BACKUP SETTINGS
# ============================================================================

# Directory to store backups (relative to project root or absolute path)
# Default: ./backups
BACKUP_DIR=./backups

# Number of days to retain backups (older backups will be deleted)
# Default: 7 days
RETENTION_DAYS=7

# Log file location (relative to project root or absolute path)
# Default: ./logs/backup.log
LOG_FILE=./logs/backup.log

# ============================================================================
# NOTIFICATION SETTINGS (Optional)
# ============================================================================

# File to log backup failures (for monitoring)
# Default: ./logs/backup-failures.log
NOTIFICATION_FILE=./logs/backup-failures.log

# Webhook URL for notifications (Slack, Discord, etc.)
# Leave empty to disable webhook notifications
# Example Slack webhook: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Example Discord webhook: https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
NOTIFICATION_WEBHOOK=

# ============================================================================
# NOTES
# ============================================================================

# 1. Get your database password from Supabase Dashboard:
#    - Go to Project Settings > Database
#    - Reset database password if needed
#    - Use the connection string format shown above

# 2. Make sure your IP is whitelisted if using IP restrictions:
#    - Supabase Dashboard > Settings > Database > Connection Pooling
#    - Enable "Allow all IPs" or add your server's IP

# 3. For production use, consider:
#    - Setting up encrypted backups
#    - Storing backups in cloud storage (S3, GCS, etc.)
#    - Using environment variables instead of this file

# 4. Test your backup:
#    ./scripts/backup-supabase.sh --full
