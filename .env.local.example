# Supabase Configuration
# Copy this file to .env.local and fill in the values

# Supabase API URL
# For local development: http://127.0.0.1:54321
# For production: https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabase Anonymous Key (public key)
# Used for client-side Supabase client
# Get from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (admin key)
# Used for server-side Supabase client with admin privileges
# ⚠️ NEVER expose this key to the browser
# Get from: Supabase Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Payment Gateway Configuration
# Secret API key for payment provider
XENDIT_SECRET_KEY=your-secret-key-here

# Webhook verification token for callbacks
XENDIT_WEBHOOK_TOKEN=your-webhook-token-here

# Public API key for client-side operations (optional)
XENDIT_PUBLIC_KEY=your-public-key-here

# Email Service Configuration (Resend)
# Get from: https://resend.com/api-keys
# Used for sending transactional emails (notifications, receipts, etc.)
RESEND_API_KEY=your-resend-api-key-here

# Push Notification Configuration
# VAPID (Voluntary Application Server Identification) Public Key
# Used for web push notifications authentication on client-side
# Generate VAPID keys using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_KEY=your-vapid-public-key-here

# Social Media Platform Configuration
# Instagram Basic Display API credentials
# Get from: Facebook Developer Portal > My Apps > Instagram Basic Display
INSTAGRAM_APP_ID=your-instagram-app-id-here
INSTAGRAM_APP_SECRET=your-instagram-app-secret-here
INSTAGRAM_REDIRECT_URI=https://your-domain.com/auth/instagram/callback

# Facebook Graph API credentials
# Get from: Facebook Developer Portal > My Apps
FACEBOOK_APP_ID=your-facebook-app-id-here
FACEBOOK_APP_SECRET=your-facebook-app-secret-here
FACEBOOK_PAGE_ID=your-facebook-page-id-here

# Sentry Error Tracking Configuration
# Get from: https://sentry.io (create a Next.js project)

# Sentry DSN (Data Source Name) - public key for error reporting
# Safe to expose to browser (NEXT_PUBLIC_ prefix)
# Get from: Sentry Dashboard > Project Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# Sentry Auth Token for source map uploads (CI/CD only)
# Get from: Sentry > Settings > Account > Auth Tokens
# ⚠️ NEVER expose this key to the browser - use only in CI/CD
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# Sentry Organization slug
# Get from: Sentry Dashboard URL (sentry.io/organizations/YOUR-ORG/)
SENTRY_ORG=your-org-slug

# Sentry Project slug
# The project name you created in Sentry
SENTRY_PROJECT=daily-worker-hub

# Application URLs
# The base URL of your application
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Firebase Configuration (Push Notifications)
# Get from: Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-firebase-vapid-key

# Firebase Admin SDK (Server-side)
# Get from: Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# VAPID Keys (Web Push Notifications)
# Generate using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CONTACT_EMAIL=mailto:your-email@example.com

# Midtrans Payment Gateway (Alternative to Xendit)
# Get from: Midtrans Dashboard > Settings > Access Keys
MIDTRANS_SERVER_KEY=your-midtrans-server-key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_API_URL=https://api.sandbox.midtrans.com
MIDTRANS_SNAP_API_URL=https://app.sandbox.midtrans.com/snap/v1

# Admin API Security
# Secret key for admin API endpoints
ADMIN_API_SECRET=your-admin-secret-here

# Cron Job Security
# Secret key for cron job endpoints
CRON_SECRET=your-cron-secret-here
